# 复制为 .env.local 后，只在本机填写真实值。
# 不要把 .env.local 发到聊天、文档、GitHub 或工作台前端。

FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=只填在本机
FEISHU_USER_MAILBOX_ID=测试邮箱的_user_mailbox_id

# 云端部署可设置为持久化挂载目录，例如 Railway Volume: /data。
# 本地留空时默认使用项目根目录。
WORKBENCH_DATA_DIR=

# 工作台真实登录保护。生产环境建议全部开启。
WORKBENCH_AUTH_REQUIRED=false
WORKBENCH_SESSION_SECRET=请改成随机长密钥
WORKBENCH_SIGNUP_INVITE_CODE=请改成内部开户注册码
WORKBENCH_SESSION_TTL_HOURS=8
WORKBENCH_REMEMBER_TTL_DAYS=30
WORKBENCH_CAPTCHA_REQUIRED=false
WORKBENCH_CAPTCHA_PROVIDER=turnstile
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# 邮件 AI 管理接口内部 Token；前端工作台不再要求直接输入它。
EMAIL_AI_ADMIN_TOKEN=请改成一串本机自定义随机口令
# 工作台管理员密码；用户在工作台输入这个密码后，由本机服务端换取内部 Token。
EMAIL_AI_ADMIN_PASSWORD=请改成本机管理员密码

# 可选，默认使用中国区飞书开放平台。
FEISHU_API_BASE=https://open.feishu.cn/open-apis

# 可选，默认读取收件箱。飞书邮件列表要求 folder_id 或 label_id 二选一。
FEISHU_MAIL_FOLDER_ID=INBOX
# FEISHU_MAIL_LABEL_ID=

# 最终版写操作配置：生产邮箱必须受控开放。
# user access token 只放本机服务端环境变量，不写入前端。
FEISHU_WRITE_ENABLED=false
FEISHU_SEND_ENABLED=false
FEISHU_ARCHIVE_ENABLED=false
FEISHU_HIGH_RISK_SEND_ENABLED=false
FEISHU_AUTO_PROCESS_ENABLED=false
FEISHU_AUTO_SEND_LOW_RISK_ENABLED=false
FEISHU_AUTO_ARCHIVE_SPAM_ENABLED=false
FEISHU_AUTO_PROCESS_SCHEDULE_ENABLED=false

# 通过 http://127.0.0.1:5175/oauth/start 自动写入，不建议手填短期 token。
FEISHU_USER_ACCESS_TOKEN=
FEISHU_USER_REFRESH_TOKEN=
FEISHU_USER_ACCESS_TOKEN_EXPIRES_AT=
FEISHU_USER_REFRESH_TOKEN_EXPIRES_AT=

# 真实发送白名单，多个邮箱用英文逗号隔开。
FEISHU_SEND_RECIPIENT_ALLOWLIST=test@example.com

# 白色垃圾邮件归档 / 移箱目标，不做硬删除。
FEISHU_ARCHIVE_FOLDER_ID=archive_folder_id

# 每日限额，防止误操作放大。
FEISHU_DAILY_SEND_LIMIT=20
FEISHU_DAILY_ARCHIVE_LIMIT=100
